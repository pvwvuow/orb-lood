# Copy to `.env` (never commit) and fill in.

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=orblood
DB_PASSWORD=changeme
DB_NAME=orblood

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-hex-string
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=4000
PUBLIC_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads
PUBLIC_UPLOADS_BASE=/uploads

# --- Voice / TURN (for WebRTC) ---
# Option 1: Self-hosted coturn (RECOMMENDED for Iran / filtered networks)
# Install coturn on the same server and set these:
TURN_HOST=
TURN_USERNAME=orblood
TURN_PASSWORD=orblood
TURN_URLS=

# Option 2: External TURN provider (ExpressTurn, Twilio, etc.)
# If TURN_URLS is set, it takes priority over auto-discovery from TURN_HOST.
# Example: TURN_URLS=turn:your-server.com:3478,turns:your-server.com:5349
EXPRESSTURN_USERNAME=
EXPRESSTURN_PASSWORD=
EXPRESSTURN_URLS=
