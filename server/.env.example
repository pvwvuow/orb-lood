# Copy to `.env` (never commit) and fill in.

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=orblood
DB_PASSWORD=changeme
DB_NAME=orblood

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-hex-string
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=4000
PUBLIC_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads
PUBLIC_UPLOADS_BASE=/uploads

# --- Voice (TURN/STUN for WebRTC media relay) ---
# If you run coturn on the same VPS (install.sh does this automatically),
# these point to your own server. No external service needed.
#
# Option A: Explicit TURN URLs (highest priority)
EXPRESSTURN_USERNAME=orblood
EXPRESSTURN_PASSWORD=
EXPRESSTURN_URLS=turns:yourdomain.com:5349?transport=tcp,turn:yourdomain.com:3478?transport=udp,turn:yourdomain.com:3478?transport=tcp
#
# Option B: Just set credentials — voice-config.js auto-derives URLs from PUBLIC_ORIGIN
COTURN_USERNAME=orblood
COTURN_PASSWORD=
