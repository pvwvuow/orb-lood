# Copy to `.env` (never commit) and fill in.

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=orblood
DB_PASSWORD=changeme
DB_NAME=orblood

# --- Auth ---
JWT_SECRET=74db701819379bb479431f7ea2669d0d02c4b980b7bf54adc64eb59b59bfbe9bf7745ad3c0265547092457749d710d64
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=4000
PUBLIC_ORIGIN=https://orblood.ir
UPLOAD_DIR=./uploads
PUBLIC_UPLOADS_BASE=/uploads

# --- Voice / TURN (self-hosted coturn on orblood.ir) ---
#
# IMPORTANT: In Iran (and many filtered/corporate networks) UDP is often
# blocked at the carrier level. The most reliable transport is TURNS
# (TURN over TLS) on port 443 — it is indistinguishable from HTTPS to
# DPI middleboxes, so it survives even aggressive filtering.
#
# Production setup runs TWO coturn instances side by side (see
# COTURN-SETUP.md and turnserver.conf):
#   * /etc/turnserver.conf       → :3478 (STUN/TURN) + :5349 (TURNS)
#   * /etc/turnserver-443.conf   → :443  (TURN + TURNS) for ISP-bypass
#
# Order of TURN_URLS matters: the browser tries them in order and picks
# the first that produces a relay candidate. Put the most reliable
# transport (turns:443?transport=tcp) FIRST so Iranian mobile carriers
# (Irancell, Hamrah-e Aval) that block UDP/3478 still get a working
# relay on what looks like a normal HTTPS connection.
#
# CDN warning: if `orblood.ir` resolves to ArvanCloud (or any HTTPS-
# terminating CDN), `turn:orblood.ir:443` and `turns:orblood.ir:443`
# will be eaten by the CDN. Use a SEPARATE subdomain (e.g.
# `turn.orblood.ir`) whose A-record points DIRECTLY to your VPS,
# bypassing the CDN. Set TURN_HOST to that subdomain.
TURN_HOST=turn.orblood.ir
TURN_USERNAME=orblood
# CRITICAL: This password MUST exactly match the `user=...` line in
# /etc/turnserver.conf (and /etc/turnserver-443.conf) on the VPS. A
# mismatch silently rejects every Allocate request and the browser
# sees only a 30-40s timeout with no error log. After changing either
# side, restart coturn AND orblood.
TURN_PASSWORD=c2b2454d70f22f44ef6308b21deb84b4
# Six-URL list, ordered by reliability on filtered networks first:
#   1) turns:443?tcp   — TLS over 443, looks like HTTPS, hardest to block
#   2) turn:443?tcp    — plain TCP over 443, tunnels through HTTP CONNECT
#   3) turn:443?udp    — UDP over 443, fastest where ISPs allow it
#   4) turns:5349?tcp  — standard TURNS port, fallback for strict NAT
#   5) turn:3478?udp   — standard STUN/TURN, blocked on most IR mobile
#   6) turn:3478?tcp   — last-resort plain TCP fallback
TURN_URLS=turns:turn.orblood.ir:443?transport=tcp,turn:turn.orblood.ir:443?transport=tcp,turn:turn.orblood.ir:443?transport=udp,turns:turn.orblood.ir:5349?transport=tcp,turn:turn.orblood.ir:3478?transport=udp,turn:turn.orblood.ir:3478?transport=tcp
# Force every byte of audio through the TURN relay (recommended for
# production on filtered networks). Set to false only for debugging
# on open networks.
VOICE_FORCE_RELAY=true
