# Copy to `.env` (never commit) and fill in.

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=orblood
DB_PASSWORD=changeme
DB_NAME=orblood

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-hex-string
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=4000
PUBLIC_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads
PUBLIC_UPLOADS_BASE=/uploads

# --- Voice (ExpressTurn) ---
# Get a free key at https://www.expressturn.com
EXPRESSTURN_USERNAME=
EXPRESSTURN_PASSWORD=
EXPRESSTURN_URLS=turn:relay1.expressturn.com:3480
